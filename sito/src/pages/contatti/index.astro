---
import Base from '../../layouts/Base.astro';
import { contatti } from '../../data/categorie.js';

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Claudio Cappelletti — Beverage Sales Agent',
  description: 'Agente di commercio nel beverage: vini e birre per ristoranti, bar e birrerie.',
  telephone: '+39 342 807 7784',
  email: 'cappellettibeverage@gmail.com',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Via San Tomaso 31/C',
    addressLocality: 'Riva del Garda',
    addressRegion: 'TN',
    addressCountry: 'IT',
  },
  areaServed: 'Garda Trentino, Trentino-Alto Adige',
  url: 'https://cappelletticlaudio.com',
});
---
<Base
  titolo="Contatti — Claudio Cappelletti · Riva del Garda"
  descrizione="Telefono, WhatsApp ed email di Claudio Cappelletti, agente di commercio beverage a Riva del Garda. Degustazioni in sede e riordini rapidi."
  temaScuro={true}
>
  <script type="application/ld+json" set:html={jsonLd} />

  <section class="contatti">
    <p class="appunto-degustazione appunto">si comincia sempre da una telefonata</p>
    <h1 class="serif">Parliamone.</h1>

    <a class="telefonone serif" href={contatti.telefonoHref}>{contatti.telefono}</a>

    <div class="canali">
      <a class="canale reveal" href={contatti.whatsapp}>
        <span class="come">WhatsApp</span>
        <span class="cosa">per riordini e richieste rapide</span>
      </a>
      <a class="canale reveal" href={`mailto:${contatti.email}`}>
        <span class="come">Email</span>
        <span class="cosa">{contatti.email}</span>
      </a>
      <div class="canale reveal">
        <span class="come">Dove</span>
        <span class="cosa">{contatti.indirizzo}</span>
      </div>
    </div>

    <div class="zona reveal">
      <h2 class="serif">La mia zona</h2>
      <p>
        La zona di lavoro è tra <strong>Riva del Garda, l'Alto Garda e il Trentino</strong>.
        Il tuo locale è più lontano? Vale comunque una telefonata: per una buona
        carta vini qualche chilometro in più non è mai stato un problema.
      </p>
    </div>
  </section>
</Base>

<style>
  .contatti {
    background: var(--vino-scuro); color: var(--crema);
    min-height: 100svh; display: grid; align-content: center; justify-items: center;
    text-align: center; padding: 20vh 6vw 14vh; gap: 0;
  }
  .appunto { font-size: 1.2rem; color: var(--rosa); }
  h1 { font-weight: 300; font-style: italic; font-size: clamp(2.6rem, 8vw, 5.5rem); margin: .2em 0 .5em; }
  .telefonone {
    font-size: clamp(1.9rem, 6vw, 3.6rem); color: var(--vino); background: var(--crema);
    text-decoration: none; padding: .35em 1em; border-radius: 999px; font-weight: 400;
    transition: background .3s, transform .3s; letter-spacing: .04em; font-family: var(--font-serif);
  }
  .telefonone:hover { background: var(--rosa); transform: translateY(-3px); }

  .canali { margin-top: 7vh; display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5em; width: min(860px, 100%); }
  @media (max-width: 760px) { .canali { grid-template-columns: 1fr; } }
  .canale {
    border: 1px solid rgba(246,240,228,.25); border-radius: 4px; padding: 1.6em 1.4em;
    text-decoration: none; color: inherit; display: grid; gap: .4em;
    transition: border-color .3s, background .3s;
  }
  a.canale:hover { border-color: var(--rosa); background: rgba(216,164,143,.08); }
  .come { font-size: .74rem; letter-spacing: .28em; text-transform: uppercase; color: var(--rosa); }
  .cosa { font-size: .95rem; opacity: .9; overflow-wrap: anywhere; }

  .zona { margin-top: 8vh; max-width: 34em; }
  .zona h2 { font-weight: 300; font-style: italic; font-size: 1.6rem; margin-bottom: .5em; }
  .zona p { opacity: .8; font-size: .98rem; }
</style>
