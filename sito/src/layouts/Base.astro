---
import { contatti } from '../data/categorie.js';

interface Props {
  titolo: string;
  descrizione: string;
  /** true per pagine che aprono su sezione scura (il body resta color vino) */
  temaScuro?: boolean;
}
const { titolo, descrizione, temaScuro = false } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
---
<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{titolo}</title>
  <meta name="description" content={descrizione} />
  <link rel="canonical" href={canonical} />
  <meta property="og:title" content={titolo} />
  <meta property="og:description" content={descrizione} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="it_IT" />
  <link rel="icon" href="/loghi/Logo-Cappelletti.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,600;1,9..144,300;1,9..144,400&family=Archivo:wght@400;500;600&display=swap" rel="stylesheet" />
</head>
<body class={temaScuro ? 'scuro' : ''}>

  <header class="testata" id="testata">
    <a class="marchio" href="/">Claudio <em>Cappelletti</em></a>
    <nav class="navi" id="navi">
      <a href="/bollicine/">Bollicine</a>
      <a href="/bianchi/">Bianchi</a>
      <a href="/rossi/">Rossi</a>
      <a href="/birre/">Birre</a>
      <a href="/chi-sono/">Chi sono</a>
      <a href="/contatti/">Contatti</a>
    </nav>
    <a class="tel-pill" href={contatti.telefonoHref}>☎ {contatti.telefono}</a>
    <button class="burger" id="burger" aria-label="Apri il menu" aria-expanded="false">
      <span></span><span></span>
    </button>
  </header>

  <slot />

  <footer class="fondo">
    <div class="fondo-inner">
      <div class="fondo-chi">
        <span class="serif">Claudio Cappelletti</span>
        <small>Agente di commercio · Beverage<br/>Ristoranti, bar e birrerie — Garda Trentino</small>
      </div>
      <div class="fondo-nav">
        <a href="/bollicine/">Le Bollicine</a>
        <a href="/bianchi/">I Bianchi</a>
        <a href="/rossi/">I Rossi</a>
        <a href="/birre/">Le Birre</a>
        <a href="/chi-sono/">Chi sono</a>
        <a href="/contatti/">Contatti</a>
      </div>
      <div class="fondo-contatti">
        <a href={contatti.telefonoHref}>{contatti.telefono}</a>
        <a href={`mailto:${contatti.email}`}>{contatti.email}</a>
        <span>{contatti.indirizzo}</span>
      </div>
    </div>
    <p class="fondo-riga">© {new Date().getFullYear()} Claudio Cappelletti · Beverage Sales Agent</p>
  </footer>

  <script>
    const burger = document.getElementById('burger');
    const testata = document.getElementById('testata');
    burger?.addEventListener('click', () => {
      const aperto = testata.classList.toggle('aperta');
      burger.setAttribute('aria-expanded', String(aperto));
    });
    document.querySelectorAll('#navi a').forEach((a) =>
      a.addEventListener('click', () => testata.classList.remove('aperta'))
    );
    // reveal generico allo scroll (elementi .reveal e sezioni .scena)
    const io = new IntersectionObserver(
      (es) => es.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('vis'); io.unobserve(e.target); } }),
      { threshold: 0.12 }
    );
    document.querySelectorAll('.reveal, .scena').forEach((el) => io.observe(el));
  </script>

  <style is:global>
    :root {
      --crema: #f6f0e4;
      --crema-2: #ece4d1;
      --inchiostro: #2b161d;
      --vino: #431223;
      --vino-scuro: #330d1b;
      --vino-chiaro: #5d1f33;
      --rame: #b26a4d;
      --rosa: #d8a48f;
      --font-serif: 'Fraunces', serif;
      --font-sans: 'Archivo', sans-serif;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      background: var(--crema);
      color: var(--inchiostro);
      font-family: var(--font-sans);
      font-size: 17px;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }
    body.scuro { background: var(--vino-scuro); color: var(--crema); }
    img { max-width: 100%; }
    .serif { font-family: var(--font-serif); font-weight: 400; }

    /* ===== testata ===== */
    .testata {
      position: fixed; top: 0; left: 0; right: 0; z-index: 90;
      display: flex; align-items: center; gap: 2em;
      padding: .8em 4vw;
      background: color-mix(in srgb, var(--vino-scuro) 86%, transparent);
      backdrop-filter: blur(10px);
      color: var(--crema);
    }
    .marchio {
      font-family: var(--font-serif); font-size: 1.15rem; letter-spacing: .02em;
      color: inherit; text-decoration: none; white-space: nowrap;
    }
    .marchio em { font-style: italic; color: var(--rosa); }
    .navi { display: flex; gap: 1.7em; margin-left: auto; }
    .navi a {
      color: inherit; text-decoration: none; font-size: .78rem;
      letter-spacing: .18em; text-transform: uppercase; opacity: .85;
      border-bottom: 1px solid transparent; padding-bottom: .2em;
      transition: opacity .25s, border-color .25s;
    }
    .navi a:hover { opacity: 1; border-color: var(--rosa); }
    .tel-pill {
      color: var(--vino); background: var(--crema); text-decoration: none;
      font-size: .78rem; letter-spacing: .12em; white-space: nowrap;
      padding: .55em 1.2em; border-radius: 999px; font-weight: 600;
      transition: background .25s, color .25s;
    }
    .tel-pill:hover { background: var(--rosa); color: var(--vino-scuro); }
    .burger { display: none; }
    @media (max-width: 900px) {
      .navi {
        position: fixed; top: 0; left: 0; right: 0; height: 100svh; padding: 18vh 8vw 0;
        background: color-mix(in srgb, var(--vino-scuro) 97%, transparent);
        flex-direction: column; gap: 1.6em; font-size: 1.2rem;
        transform: translateY(-105%); transition: transform .45s cubic-bezier(.22,1,.36,1);
        z-index: -1; overflow: hidden;
      }
      .navi a { font-size: 1rem; letter-spacing: .22em; }
      .testata.aperta .navi { transform: none; }
      .burger { display: grid; gap: 6px; background: none; border: 0; cursor: pointer; padding: 6px; }
      .burger span { width: 26px; height: 2px; background: var(--crema); transition: transform .3s, opacity .3s; }
      .testata.aperta .burger span:nth-child(1) { transform: translateY(4px) rotate(45deg); }
      .testata.aperta .burger span:nth-child(2) { transform: translateY(-4px) rotate(-45deg); }
      .testata { gap: 1em; }
      .tel-pill { margin-left: auto; font-size: .7rem; padding: .5em .9em; }
      .marchio { font-size: 1.02rem; }
    }

    /* ===== footer ===== */
    .fondo { background: var(--vino-scuro); color: var(--crema); padding: 9vh 6vw 4vh; }
    .fondo-inner {
      display: grid; grid-template-columns: 1.2fr 1fr 1.2fr; gap: 3em;
      max-width: 1100px; margin: 0 auto;
      padding-bottom: 5vh; border-bottom: 1px solid rgba(246,240,228,.18);
    }
    @media (max-width: 800px) { .fondo-inner { grid-template-columns: 1fr; } }
    .fondo-chi .serif { font-size: 1.5rem; display: block; margin-bottom: .5em; }
    .fondo-chi small { opacity: .65; letter-spacing: .08em; line-height: 1.9; }
    .fondo-nav { display: grid; gap: .55em; align-content: start; }
    .fondo-nav a, .fondo-contatti a {
      color: inherit; text-decoration: none; opacity: .8; font-size: .9rem;
      transition: opacity .2s, color .2s;
    }
    .fondo-nav a:hover, .fondo-contatti a:hover { opacity: 1; color: var(--rosa); }
    .fondo-contatti { display: grid; gap: .55em; align-content: start; font-size: .9rem; }
    .fondo-contatti span { opacity: .65; }
    .fondo-riga {
      text-align: center; padding-top: 3.5vh; font-size: .72rem;
      letter-spacing: .28em; text-transform: uppercase; opacity: .45;
    }

    /* ===== utilità condivise ===== */
    .reveal { opacity: 0; transform: translateY(28px); transition: opacity .9s cubic-bezier(.22,1,.36,1), transform .9s cubic-bezier(.22,1,.36,1); }
    .reveal.vis { opacity: 1; transform: none; }

    /* titoli che emergono da una maschera: <h2 class="maschera"><span>testo</span></h2> */
    .maschera { overflow: hidden; }
    .maschera > span { display: inline-block; transform: translateY(115%); transition: transform 1.1s cubic-bezier(.22,1,.36,1); }
    .scena.vis .maschera > span, .maschera.vis > span { transform: none; }

    /* appunto di degustazione: corsivo serif con filetto, al posto della grafia a mano */
    .appunto-degustazione {
      font-family: var(--font-serif); font-style: italic; font-weight: 300;
      display: inline-flex; align-items: center; gap: .9em;
    }
    .appunto-degustazione::before { content: ""; width: 2.2em; height: 1px; background: currentColor; opacity: .55; }

    @media (prefers-reduced-motion: reduce) {
      .reveal, .maschera > span { opacity: 1; transform: none; transition: none; }
    }

    .bottone {
      display: inline-block; text-decoration: none; color: inherit;
      font-size: .82rem; letter-spacing: .2em; text-transform: uppercase;
      border: 1px solid currentColor; padding: 1em 2.1em; border-radius: 999px;
      transition: background .3s, color .3s, border-color .3s;
    }
    /* pieno = per sezioni chiare; chiaro = per sezioni scure */
    .bottone.pieno { background: var(--vino); border-color: var(--vino); color: var(--crema); font-weight: 600; }
    .bottone.pieno:hover { background: var(--vino-chiaro); border-color: var(--vino-chiaro); color: var(--crema); }
    .bottone.chiaro { background: var(--crema); border-color: var(--crema); color: var(--vino); font-weight: 600; }
    .bottone.chiaro:hover { background: var(--rosa); border-color: var(--rosa); color: var(--vino-scuro); }
    .bottone:not(.pieno):not(.chiaro):hover { background: var(--crema); color: var(--vino); border-color: var(--crema); }
  </style>
</body>
</html>
