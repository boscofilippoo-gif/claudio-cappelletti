---
import Base from '../../layouts/Base.astro';
import { contatti, cantine } from '../../data/categorie.js';
---
<Base
  titolo="Chi sono — Claudio Cappelletti, agente di commercio beverage"
  descrizione="Claudio Cappelletti, agente di commercio nel beverage a Riva del Garda: vini e birre per ristoranti, bar e birrerie del Garda Trentino."
  temaScuro={true}
>
  <section class="apertura">
    <div class="testo">
      <p class="occhiello">Chi sono</p>
      <h1 class="serif">Dietro ogni carta dei vini<br/>c'è un lavoro <em>fatto di persona</em>.</h1>
      <p class="riga">
        Claudio Cappelletti, agente di commercio nel beverage.
        Base a <strong>Riva del Garda</strong>, zona di lavoro tra il lago e il Trentino:
        gli stessi locali, le stesse strade, da anni.
      </p>
    </div>
    <figure class="pola">
      <img src="/foto/corks-web.jpg" alt="Un bianco di Vetrere nel ghiaccio, in riva al lago" width="700" height="466" />
      <figcaption class="serif">Il mestiere, d'estate</figcaption>
    </figure>
  </section>

  <section class="valori">
    <div class="valore reveal">
      <h2 class="serif">Ogni etichetta, assaggiata prima di essere proposta</h2>
      <p>In catalogo non entra nulla che non sia stato bevuto, valutato e scelto di persona.
      Sessanta etichette da quindici cantine — quasi tutte piccole, a conduzione familiare.</p>
    </div>
    <div class="valore reveal">
      <h2 class="serif">Il locale prima del listino</h2>
      <p>Un rifugio in montagna e un cocktail bar sul lago non hanno bisogno delle stesse bottiglie.
      Prima si ascolta, poi si propone: carta vini, prezzi, rotazioni stagionali.</p>
    </div>
    <div class="valore reveal">
      <h2 class="serif">Di zona, davvero</h2>
      <p>Il Lugana finito il venerdì sera non aspetta un modulo online:
      basta un messaggio e il riordino parte. È la differenza tra un portale e una persona.</p>
    </div>
  </section>

  <section class="cantine-sez">
    <p class="appunto-degustazione reveal">quindici realtà, un'unica selezione</p>
    <h2 class="serif reveal">Le cantine rappresentate</h2>
    <ul class="lista reveal">
      {cantine.map((c) => <li>{c}</li>)}
    </ul>
  </section>

  <section class="congedo">
    <h2 class="serif reveal">Ci vediamo al tuo banco?</h2>
    <div class="azioni reveal">
      <a class="bottone chiaro" href={contatti.telefonoHref}>{contatti.telefono}</a>
      <a class="bottone" href={contatti.whatsapp}>WhatsApp</a>
    </div>
  </section>
</Base>

<style>
  .apertura {
    background: var(--vino-scuro); color: var(--crema);
    display: grid; grid-template-columns: 1.1fr .9fr; gap: 5em; align-items: center;
    padding: 22vh 8vw 12vh;
  }
  @media (max-width: 900px) { .apertura { grid-template-columns: 1fr; gap: 3.5em; padding-top: 18vh; } }
  .occhiello { font-size: .76rem; letter-spacing: .32em; text-transform: uppercase; opacity: .65; margin-bottom: 1.6em; }
  h1 { font-weight: 300; font-size: clamp(2rem, 4.8vw, 3.6rem); line-height: 1.12; }
  h1 em { font-style: italic; color: var(--rosa); }
  .riga { margin-top: 1.8em; max-width: 30em; opacity: .9; font-size: 1.05rem; }

  .pola { background: #fbf6ec; padding: 12px 12px 46px; box-shadow: 0 20px 50px rgba(20,5,12,.5); transform: rotate(2deg); position: relative; justify-self: center; max-width: 440px; }
  .pola img { display: block; width: 100%; height: auto; aspect-ratio: 4/3; object-fit: cover; }
  .pola figcaption { position: absolute; bottom: 10px; left: 0; right: 0; text-align: center; font-style: italic; font-size: 1rem; color: #5c4049; }

  .valori {
    background: var(--crema); color: var(--inchiostro);
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 3.5em;
    padding: 13vh 8vw;
  }
  @media (max-width: 900px) { .valori { grid-template-columns: 1fr; max-width: 560px; margin: 0 auto; } }
  .valore h2 { font-weight: 400; font-size: 1.35rem; line-height: 1.3; margin-bottom: .6em; }
  .valore p { font-size: .96rem; opacity: .8; }

  .cantine-sez { background: var(--vino); color: var(--crema); text-align: center; padding: 13vh 8vw; }
  .cantine-sez .appunto-degustazione { color: var(--rosa); font-size: 1.1rem; justify-content: center; }
  .cantine-sez h2 { font-weight: 300; font-style: italic; font-size: clamp(1.8rem, 4vw, 2.6rem); margin: .3em 0 1.8em; }
  .lista { list-style: none; display: flex; flex-wrap: wrap; gap: .8em 1em; justify-content: center; max-width: 760px; margin: 0 auto; }
  .lista li {
    font-family: var(--font-serif); font-style: italic; font-size: 1.05rem;
    border: 1px solid color-mix(in srgb, var(--rosa) 40%, transparent); padding: .45em 1.3em; border-radius: 999px;
  }

  .congedo { background: var(--vino-scuro); color: var(--crema); text-align: center; padding: 14vh 8vw; }
  .congedo h2 { font-weight: 300; font-style: italic; font-size: clamp(2rem, 5.5vw, 3.4rem); margin-bottom: 1em; }
  .azioni { display: flex; gap: 1em; justify-content: center; flex-wrap: wrap; }
</style>
